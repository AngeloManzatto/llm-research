{
  "benchmark_id": "conversation_level0",
  "version": "0.1.0",
  "description": "Deterministic Level 0 conversation benchmark for pretrained NTP models.",
  "data_files": [
    "data/openai/openai_core_0001.jsonl"
  ],
  "default_decode": {
    "strategy": "greedy",
    "max_length": 64,
    "stop_tokens": [
        "END_OF_TURN"
    ]
  },
  "scoring_metric": "contains_expected",
  "diagnostic_metrics": [
    "wiki_talk_artifact",
    "repetition",
    "word_count",
    "too_long",
    "expected_stop_token"
  ]
}